{
	"info": {
		"_postman_id": "ffe70b79-5cbb-44c8-9b6b-5ab1ed97fc01",
		"name": "RESTful_API_Foody",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "39956208"
	},
	"item": [
		{
			"name": "User Authentication",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {\r",
							"    pm.response.to.have.status(200);\r",
							"});\r",
							"\r",
							"const jsonData = pm.response.json()\r",
							"pm.test(\"Response body includes username, password, and accessToken\", function () {\r",
							"    pm.expect(jsonData).to.have.property(\"username\");\r",
							"    pm.expect(jsonData).to.have.property(\"password\");\r",
							"    pm.expect(jsonData).to.have.property(\"accessToken\");\r",
							"})\r",
							"\r",
							"pm.collectionVariables.set(\"token\", jsonData.accessToken);"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\r\n    \"userName\": \"VasiMii\",\r\n    \"password\": \"Parola12\"\r\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseURL}}/api/User/Authentication",
					"host": [
						"{{baseURL}}"
					],
					"path": [
						"api",
						"User",
						"Authentication"
					]
				}
			},
			"response": []
		},
		{
			"name": "Create New Food",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"function generateRandomFood() {\r",
							"    const words = [\"Pizza\", \"Burger\", \"Sushi\", \"Pasta\", \"Taco\", \"Salad\"];\r",
							"    const digits = Math.floor(Math.random() * 1000);\r",
							"    return words[Math.floor(Math.random() * words.length)] + digits;\r",
							"}\r",
							"\r",
							"pm.collectionVariables.set(\"randomFood\", generateRandomFood());\r",
							""
						],
						"type": "text/javascript",
						"packages": {}
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 201\", function () {\r",
							"    pm.response.to.have.status(201);\r",
							"});\r",
							"\r",
							"const jsonData = pm.response.json();\r",
							"\r",
							"pm.test(\"Response contains foodId\", function () {\r",
							"    pm.expect(jsonData).to.have.property(\"foodId\");\r",
							"    pm.collectionVariables.set(\"foodId\", jsonData.foodId);\r",
							"});\r",
							""
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\r\n  \"name\": \"{{randomFood}}\",\r\n  \"description\": \"Delicious and fresh food\"\r\n}\r\n",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseURL}}/api/Food/Create",
					"host": [
						"{{baseURL}}"
					],
					"path": [
						"api",
						"Food",
						"Create"
					]
				}
			},
			"response": []
		},
		{
			"name": "Search Food By Name",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () { \r",
							"    pm.response.to.have.status(200)\r",
							"})\r",
							"pm.test(\"Food name is the same as the one in the request\", function () {\r",
							"    const responseJson = pm.response.json();\r",
							"    const foodName = pm.collectionVariables.get(\"randomFood\");\r",
							"    pm.expect(responseJson[0].name).to.be.eql(foodName);\r",
							"})"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"protocolProfileBehavior": {
				"disableBodyPruning": true
			},
			"request": {
				"method": "GET",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseURL}}/api/Food/Search?keyword={{randomFood}}",
					"host": [
						"{{baseURL}}"
					],
					"path": [
						"api",
						"Food",
						"Search"
					],
					"query": [
						{
							"key": "keyword",
							"value": "{{randomFood}}"
						}
					]
				}
			},
			"response": []
		},
		{
			"name": "Edit the Name of Created Food",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () { \r",
							"    pm.response.to.have.status(200)\r",
							"})\r",
							"\r",
							"const jsonData = pm.response.json()\r",
							"\r",
							"pm.test(\"Response includes current msg\", function () {\r",
							"    pm.expect(jsonData.msg).to.eql(\"Successfully edited\")\r",
							"})"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "PATCH",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "    [\r\n    {\r\n        \"path\": \"/name\",\r\n        \"op\": \"replace\",\r\n        \"value\": \"Very Tasty\"\r\n    }\r\n    ]",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseURL}}/api/Food/Edit/{{foodId}}",
					"host": [
						"{{baseURL}}"
					],
					"path": [
						"api",
						"Food",
						"Edit",
						"{{foodId}}"
					]
				}
			},
			"response": []
		},
		{
			"name": "Delete the Edited Food",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () { \r",
							"    pm.response.to.have.status(200);\r",
							"});\r",
							"\r",
							"const jsonData = pm.response.json();\r",
							"\r",
							"pm.test(\"Response message is 'Deleted successfully!'\", function () {\r",
							"    pm.expect(jsonData).to.be.an(\"object\");\r",
							"    pm.expect(jsonData).to.have.property(\"msg\");\r",
							"    pm.expect(jsonData.msg).to.eql(\"Deleted successfully!\");\r",
							"});\r",
							""
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "DELETE",
				"header": [],
				"url": {
					"raw": "{{baseURL}}/api/Food/Delete/{{foodId}}",
					"host": [
						"{{baseURL}}"
					],
					"path": [
						"api",
						"Food",
						"Delete",
						"{{foodId}}"
					]
				}
			},
			"response": []
		}
	],
