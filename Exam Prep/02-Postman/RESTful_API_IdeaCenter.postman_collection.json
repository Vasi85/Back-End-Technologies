		{
			"name": "Create New Idea",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"function generateRandomTitle() {\r",
							"    const words = [\"Idea\", \"Thought\", \"Concept\", \"Vision\", \"Plan\", \"Goal\"];\r",
							"    const word = words[Math.floor(Math.random() * words.length)];\r",
							"    const digits = Math.floor(Math.random() * 1000); // up to 3 digits\r",
							"    return word + digits;\r",
							"}\r",
							"\r",
							"const title = generateRandomTitle();\r",
							"pm.collectionVariables.set(\"randomTitle\", title)"
						],
						"type": "text/javascript",
						"packages": {}
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () { \r",
							"    pm.response.to.have.status(200)\r",
							"})\r",
							"\r",
							"const jsonData = pm.response.json()\r",
							"\r",
							"pm.test(\"Response includes current attributes\", function () {\r",
							"    pm.expect(jsonData.msg).to.eql(\"Successfully created!\")\r",
							"    pm.expect(jsonData.idea).to.have.property(\"title\")\r",
							"    pm.expect(jsonData.idea).to.have.property(\"description\")\r",
							"})"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..XQJT8e3NsO9BtYTuYKbphLD3oCd5iA53Ty29qpyeN3M",
							"type": "string"
						}
