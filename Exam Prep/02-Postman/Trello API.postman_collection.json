		{
			"name": "Create a TO DO List",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();\r",
							"\r",
							"pm.test(\"Response has all the expected properties\", function() {\r",
							"    pm.expect(jsonData).to.not.be.null; // Check for null\r",
							"    pm.expect(jsonData).to.not.be.undefined; // Check for undefined\r",
							"    pm.expect(jsonData).to.have.all.keys('id', 'name', 'closed', 'color', 'idBoard', 'pos', 'type', 'datasource', 'limits');\r",
							"});\r",
							"\r",
							"pm.test(\"'closed' is false and of type boolean\", function(){\r",
							"    pm.expect(jsonData.closed).to.be.a('boolean');\r",
							"    pm.expect(jsonData.closed).to.be.false;\r",
							"});\r",
							"\r",
							"pm.test(\"'idBoard' matches expected board ID\", function(){\r",
							"    var expectedBoardId = pm.variables.get(\"boardID\");\r",
							"    pm.expect(jsonData.idBoard).to.be.eql(expectedBoardId);\r",
							"});\r",
							""
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
